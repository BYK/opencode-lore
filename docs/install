#!/bin/bash
set -euo pipefail

RED='\033[0;31m'
MUTED='\033[0;2m'
GREEN='\033[0;32m'
NC='\033[0m'

die() {
  echo -e "${RED}$1${NC}" >&2
  exit 1
}

# Catch unexpected failures from set -e / pipefail
trap 'die "Unexpected failure at line $LINENO"' ERR

usage() {
  cat <<EOF
Lore Installer — persistent memory for AI coding agents

Usage: install [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version (e.g., 0.14.0)
        --no-modify-path    Don't modify shell config files (.zshrc, .bashrc, etc.)

Environment Variables:
    LORE_INSTALL_DIR        Override the installation directory
    LORE_VERSION            Install a specific version (e.g., 0.14.0)

Examples:
    curl -fsSL https://withlore.ai/install | bash
    curl -fsSL https://withlore.ai/install | bash -s -- --version 0.14.0
    LORE_INSTALL_DIR=~/.local/bin curl -fsSL https://withlore.ai/install | bash
EOF
}

requested_version="${LORE_VERSION:-}"
no_modify_path=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -v|--version)
      if [[ -n "${2:-}" ]]; then
        requested_version="$2"
        shift 2
      else
        die "Error: --version requires a version argument"
      fi
      ;;
    --no-modify-path)
      no_modify_path=true
      shift
      ;;
    *) shift ;;
  esac
done

# ---------------------------------------------------------------------------
# Detect platform
# ---------------------------------------------------------------------------

case "$(uname -s)" in
  Darwin*) os="darwin" ;;
  Linux*)  os="linux" ;;
  MINGW*|MSYS*|CYGWIN*) os="windows" ;;
  *) die "Unsupported OS: $(uname -s)" ;;
esac

arch=$(uname -m)
case "$arch" in
  x86_64)       arch="x64" ;;
  aarch64|arm64) arch="arm64" ;;
  *) die "Unsupported architecture: $arch" ;;
esac

suffix=""
if [[ "$os" == "windows" ]]; then
  suffix=".exe"
  if [[ "$arch" != "x64" ]]; then
    die "Unsupported: windows-$arch (only windows-x64 is supported)"
  fi
fi

# ---------------------------------------------------------------------------
# Resolve version
# ---------------------------------------------------------------------------

version=""
if [[ -z "$requested_version" ]]; then
  echo -e "${MUTED}Fetching latest version...${NC}"
  version=$(curl -fsSL https://api.github.com/repos/BYK/loreai/releases/latest \
    | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p')
  if [[ -z "$version" ]]; then
    die "Failed to fetch latest version from GitHub"
  fi
else
  version="$requested_version"
fi

# Strip leading 'v' if present
version="${version#v}"

echo -e "${MUTED}Installing lore v${version} (${os}-${arch})...${NC}"

# ---------------------------------------------------------------------------
# Download binary
# ---------------------------------------------------------------------------

tmpdir="${TMPDIR:-${TMP:-${TEMP:-/tmp}}}"
tmp_binary="${tmpdir}/lore-install-$$${suffix}"

trap 'rm -f "$tmp_binary"' EXIT

filename="lore-${os}-${arch}${suffix}"
url="https://github.com/BYK/loreai/releases/download/${version}/${filename}"

# Try gzip-compressed first (~60% smaller), fall back to raw binary
if curl -fsSL "${url}.gz" 2>/dev/null | gunzip > "$tmp_binary" 2>/dev/null; then
  : # Compressed download succeeded
else
  curl -fsSL --progress-bar "$url" -o "$tmp_binary"
fi

chmod +x "$tmp_binary"

# Quick sanity check
if ! "$tmp_binary" --version >/dev/null 2>&1; then
  die "Downloaded binary failed sanity check. Platform: ${os}-${arch}"
fi

# ---------------------------------------------------------------------------
# Install to destination
# ---------------------------------------------------------------------------

install_dir="${LORE_INSTALL_DIR:-$HOME/.local/bin}"
mkdir -p "$install_dir"

dest="${install_dir}/lore${suffix}"
mv "$tmp_binary" "$dest"
trap - EXIT  # Clear the temp-file cleanup trap

installed_version=$("$dest" --version 2>/dev/null || echo "$version")
echo -e "${GREEN}✓ lore v${installed_version} installed to ${dest}${NC}"

# ---------------------------------------------------------------------------
# PATH setup
# ---------------------------------------------------------------------------

if [[ "$no_modify_path" == "true" ]]; then
  if ! echo "$PATH" | tr ':' '\n' | grep -qx "$install_dir"; then
    echo ""
    echo "Add lore to your PATH:"
    echo "  export PATH=\"${install_dir}:\$PATH\""
  fi
  exit 0
fi

# Check if install_dir is already in PATH
if echo "$PATH" | tr ':' '\n' | grep -qx "$install_dir"; then
  exit 0
fi

path_line="export PATH=\"${install_dir}:\$PATH\""
modified=false

# Detect shell config files to modify
configs=()
shell_name=$(basename "${SHELL:-/bin/sh}")
case "$shell_name" in
  zsh)  configs+=("$HOME/.zshrc") ;;
  bash)
    # .bash_profile for login shells, .bashrc for interactive
    [[ -f "$HOME/.bash_profile" ]] && configs+=("$HOME/.bash_profile")
    configs+=("$HOME/.bashrc")
    ;;
  fish) configs+=("$HOME/.config/fish/config.fish") ;;
  *)    configs+=("$HOME/.profile") ;;
esac

for rc in "${configs[@]}"; do
  if [[ -f "$rc" ]] && grep -qF "$install_dir" "$rc" 2>/dev/null; then
    continue  # Already configured
  fi
  echo "" >> "$rc"
  echo "# Added by lore installer" >> "$rc"
  if [[ "$shell_name" == "fish" ]]; then
    echo "set -gx PATH \"${install_dir}\" \$PATH" >> "$rc"
  else
    echo "$path_line" >> "$rc"
  fi
  modified=true
  echo -e "${MUTED}Updated ${rc}${NC}"
done

if [[ "$modified" == "true" ]]; then
  echo ""
  echo "Restart your shell or run:"
  echo "  $path_line"
fi
